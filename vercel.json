{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/rss/sync",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/rss/sync",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/sync/run",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/automations/wati-sync",
      "schedule": "0 */2 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "routes": [
    {
      "src": "/\\.(env|git|aws|ssh|htaccess|htpasswd|dockerignore|npmrc)(.*)",
      "mitigate": { "action": "deny" }
    },
    {
      "src": "/.*\\.(sql|bak|log|conf|ini|key|pem|p12|pfx|crt|csr|der|swp|swo|old|orig|dist|map\\.js)$",
      "mitigate": { "action": "deny" }
    },
    {
      "src": "/(wp-admin|wp-login|wp-content|wordpress|phpMyAdmin|phpmyadmin|pma)(.*)",
      "mitigate": { "action": "deny" }
    },
    {
      "src": "/(cgi-bin|admin\\.php|xmlrpc\\.php|wp-cron\\.php|setup\\.php|config\\.php|server-status|actuator|solr|console)(.*)",
      "mitigate": { "action": "deny" }
    },
    {
      "src": "/(shell|cmd|eval|exec|invoke|debug|trace|test\\.php|info\\.php|phpinfo)(.*)",
      "mitigate": { "action": "deny" }
    },
    {
      "src": "/(\\.|_)(git|svn|hg|bzr|DS_Store|idea|vscode)(.*)",
      "mitigate": { "action": "deny" }
    },
    {
      "src": "/(backup|backups|db|database|dump|dumps|mysql|postgres|redis|mongo|elastic)(.*)",
      "mitigate": { "action": "deny" }
    }
  ]
}
