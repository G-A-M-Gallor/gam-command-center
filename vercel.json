{
  "crons": [
    {
      "path": "/api/rss/sync",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/rss/sync",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/sync/run",
      "schedule": "*/5 * * * *"
    }
  ],
  "routes": [
    {
      "src": "/\\.(env|git|aws|ssh|htaccess|htpasswd)(.*)",
      "mitigate": { "action": "deny" }
    },
    {
      "src": "/(wp-admin|wp-login|wp-content|wordpress|phpMyAdmin|phpmyadmin|pma)(.*)",
      "mitigate": { "action": "deny" }
    },
    {
      "src": "/(cgi-bin|admin\\.php|xmlrpc\\.php|wp-cron\\.php|setup\\.php|config\\.php|server-status|actuator|solr|console)(.*)",
      "mitigate": { "action": "deny" }
    }
  ]
}
