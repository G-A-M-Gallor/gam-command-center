# ═══════════════════════════════════════════════════════════
# vBrain.io — Environment Variables
# Copy to .env.local and fill in values
# ═══════════════════════════════════════════════════════════

# ─── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=                          # Supabase → Settings → API → JWT Secret (Legacy)

# ─── Auth ─────────────────────────────────────────────────
NEXTAUTH_SECRET=                              # openssl rand -base64 32
NEXTAUTH_URL=https://vbrain.io                # NextAuth URL for OAuth callbacks
NEXT_PUBLIC_APP_URL=https://vbrain.io         # Base URL for redirects
ALLOWED_EMAILS=user@example.com               # Comma-separated allowlist

# ─── AI ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...                  # Claude API
GOOGLE_AI_API_KEY=                            # Google Gemini AI API
VOYAGE_API_KEY=                               # Voyage AI embeddings (optional)

# ─── Notion ───────────────────────────────────────────────
NOTION_API_KEY=ntn_...                        # Notion integration token
NOTION_TASKS_DB_ID=25a2ef60-2865-4c6a-bbe5-7c6fb97504ed

# ─── Origami CRM ─────────────────────────────────────────
ORIGAMI_API_KEY=                              # Origami admin panel
ORIGAMI_BASE_URL=                             # Origami API URL
ORIGAMI_USERNAME=
ORIGAMI_API_SECRET=

# ─── Email (Resend) ──────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=

# ─── WhatsApp (WATI) ─────────────────────────────────────
WATI_API_URL=
WATI_API_TOKEN=
NEXT_PUBLIC_WATI_URL=                         # Widget embed URL
WATI_WEBHOOK_SECRET=

# ─── Google OAuth ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=                  # openssl rand -hex 32

# ─── Push Notifications (VAPID) ──────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:gal@gam.co.il

# ─── Phone (Voicenter) ───────────────────────────────────
VOICENTER_API_KEY=
VOICENTER_WEBHOOK_SECRET=

# ─── Monitoring ───────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# ─── File Storage ─────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=                        # Vercel Blob storage token

# ─── Security & Encryption ────────────────────────────────
SYNC_ENCRYPTION_KEY=                          # 32-char hex key for data encryption (openssl rand -hex 32)

# ─── Automation ───────────────────────────────────────────
NEXT_PUBLIC_N8N_URL=                          # n8n iframe URL
CRON_SECRET=                                  # openssl rand -hex 32 (Vercel Cron)
