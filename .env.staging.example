# GAM Command Center - Staging Environment Configuration
# Copy this file to .env.staging and update with actual staging values

# =========================================================================
# CORE APPLICATION SETTINGS
# =========================================================================
NEXT_PUBLIC_APP_URL="https://vbrain-staging.vercel.app"
NEXTAUTH_SECRET="staging-secret-key-here"
NODE_ENV="staging"

# =========================================================================
# SUPABASE STAGING PROJECT
# =========================================================================
# Create new staging project at: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL="https://[staging-project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="staging-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="staging-service-role-key-here"
SUPABASE_JWT_SECRET="staging-jwt-secret-here"

# =========================================================================
# AI & EXTERNAL SERVICES (SHARED WITH PRODUCTION)
# =========================================================================
ANTHROPIC_API_KEY="sk-ant-api03-[shared-key]"
GOOGLE_AI_API_KEY="[shared-key]"
NOTION_API_KEY="[shared-key]"

# =========================================================================
# STAGING-SPECIFIC CRON & SYNC
# =========================================================================
CRON_SECRET="staging-cron-secret-here"
SYNC_ENCRYPTION_KEY="staging-encryption-key-here"

# =========================================================================
# COMMUNICATION (STAGING SANDBOX)
# =========================================================================
RESEND_API_KEY="[staging-sandbox-key]"
RESEND_WEBHOOK_SECRET="[staging-webhook-secret]"

# =========================================================================
# PUSH NOTIFICATIONS (STAGING VAPID)
# =========================================================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY="[staging-vapid-public]"
VAPID_PRIVATE_KEY="[staging-vapid-private]"

# =========================================================================
# EXTERNAL INTEGRATIONS (SANDBOX/TEST ACCOUNTS)
# =========================================================================
ORIGAMI_USERNAME="staging@gam.co.il"
ORIGAMI_API_KEY="[staging-origami-key]"

# =========================================================================
# DEVELOPMENT & PERFORMANCE SETTINGS
# =========================================================================
NX_DAEMON="false"
TURBO_CACHE="remote:rw"
TURBO_DOWNLOAD_LOCAL_ENABLED="true"
TURBO_REMOTE_ONLY="false"
TURBO_RUN_SUMMARY="true"

# =========================================================================
# STAGING-SPECIFIC FLAGS
# =========================================================================
STAGING_MODE="true"
DEBUG_MODE="true"
LOG_LEVEL="debug"
STAGING_BANNER="true"