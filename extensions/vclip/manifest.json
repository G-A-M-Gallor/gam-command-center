{
  "manifest_version": 3,
  "name": "vClip — Screen Recorder",
  "version": "0.1.0",
  "description": "Record screen + face bubble, compress & share instantly",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "offscreen"
  ],
  "host_permissions": [
    "https://*.vbrain.io/*",
    "https://vbrain-io.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
